{
  "name": "dev3-fullstack-tp1",
  "version": "1.0.0",
  "description": "Monorepo racine",
  "scripts": {
    "setup": "npm install --prefix server && npm install --prefix client",
    "start:server": "npm run dev --prefix server",
    "start:client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "test:serveur": "npm test --prefix server"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "sequelize": "^6.37.8",
    "sqlite3": "^6.0.1"
  }
}
